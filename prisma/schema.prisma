generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// USERS
// ─────────────────────────────────────────

model User {
  id              String        @id @default(uuid())
  username        String        @unique @db.VarChar(30)
  email           String        @unique @db.VarChar(255)
  passwordHash    String
  avatarUrl       String?
  level           Int           @default(1)
  xp              Int           @default(0)
  coins           Int           @default(0)
  rankPoints      Int           @default(0)
  accountStatus   AccountStatus @default(ACTIVE)
  emailVerified   Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  lastLogin       DateTime?

  statistics      PlayerStatistics?
  settings        PlayerSettings?
  cosmetics       PlayerCosmetic[]
  sentRequests    FriendRequest[]   @relation("SentRequests")
  receivedRequests FriendRequest[]  @relation("ReceivedRequests")
  friendsAsOne    Friend[]          @relation("FriendOne")
  friendsAsTwo    Friend[]          @relation("FriendTwo")
  matchPlayers    MatchPlayer[]
  notifications   Notification[]
  reportsGiven    Report[]          @relation("Reporter")
  reportsReceived Report[]          @relation("Reported")
  leaderboard     Leaderboard?

  @@index([username])
  @@index([email])
  @@index([rankPoints])
  @@index([lastLogin])
}

// ─────────────────────────────────────────
// PLAYER STATISTICS
// ─────────────────────────────────────────

model PlayerStatistics {
  id                 String   @id @default(uuid())
  userId             String   @unique
  gamesPlayed        Int      @default(0)
  gamesWon           Int      @default(0)
  gamesLost          Int      @default(0)
  winRate            Float    @default(0)
  longestWinStreak   Int      @default(0)
  currentWinStreak   Int      @default(0)
  cardsPlayed        Int      @default(0)
  cardsDrawn         Int      @default(0)
  totalPlayTime      BigInt   @default(0)

  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─────────────────────────────────────────
// PLAYER SETTINGS
// ─────────────────────────────────────────

model PlayerSettings {
  id             String   @id @default(uuid())
  playerId       String   @unique
  language       String   @default("en")
  musicVolume    Int      @default(80)
  soundVolume    Int      @default(80)
  voiceVolume    Int      @default(80)
  pushToTalk     Boolean  @default(false)
  notifications  Boolean  @default(true)
  darkMode       Boolean  @default(true)

  user           User     @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
}

// ─────────────────────────────────────────
// FRIENDS
// ─────────────────────────────────────────

model Friend {
  id        String   @id @default(uuid())
  userOne   String
  userTwo   String
  createdAt DateTime @default(now())

  userOneRef User @relation("FriendOne", fields: [userOne], references: [id], onDelete: Cascade)
  userTwoRef User @relation("FriendTwo", fields: [userTwo], references: [id], onDelete: Cascade)

  @@unique([userOne, userTwo])
  @@index([userOne])
  @@index([userTwo])
}

// ─────────────────────────────────────────
// FRIEND REQUESTS
// ─────────────────────────────────────────

model FriendRequest {
  id         String        @id @default(uuid())
  senderId   String
  receiverId String
  status     RequestStatus @default(PENDING)
  createdAt  DateTime      @default(now())

  sender     User @relation("SentRequests", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User @relation("ReceivedRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
}

// ─────────────────────────────────────────
// MATCH HISTORY
// ─────────────────────────────────────────

model Match {
  id          String     @id @default(uuid())
  roomId      String
  winnerId    String?
  duration    Int
  gameMode    GameMode
  totalTurns  Int        @default(0)
  startedAt   DateTime
  endedAt     DateTime

  players     MatchPlayer[]

  @@index([roomId])
  @@index([winnerId])
}

// ─────────────────────────────────────────
// MATCH PLAYERS
// ─────────────────────────────────────────

model MatchPlayer {
  id             String @id @default(uuid())
  matchId        String
  playerId       String
  finalPosition  Int
  cardsRemaining Int    @default(0)
  ratingChange   Int    @default(0)
  xpEarned       Int    @default(0)

  match          Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player         User   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@index([playerId])
}

// ─────────────────────────────────────────
// LEADERBOARD
// ─────────────────────────────────────────

model Leaderboard {
  id       String @id @default(uuid())
  playerId String @unique
  rating   Int    @default(1000)
  tier     String @default("BRONZE")
  division String @default("III")
  season   Int    @default(1)

  user     User   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([rating])
  @@index([playerId])
}

// ─────────────────────────────────────────
// COSMETICS
// ─────────────────────────────────────────

model PlayerCosmetic {
  id           String        @id @default(uuid())
  playerId     String
  cosmeticType CosmeticType
  cosmeticId   String
  unlockedAt   DateTime      @default(now())

  user         User          @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
}

// ─────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────

model Notification {
  id        String   @id @default(uuid())
  playerId  String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
}

// ─────────────────────────────────────────
// REPORTS
// ─────────────────────────────────────────

model Report {
  id             String       @id @default(uuid())
  reporterId     String
  reportedPlayer String
  reason         String
  matchId        String?
  status         ReportStatus @default(PENDING)

  reporter       User         @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reported       User         @relation("Reported", fields: [reportedPlayer], references: [id], onDelete: Cascade)

  @@index([reporterId])
  @@index([reportedPlayer])
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum AccountStatus {
  ACTIVE
  BANNED
  SUSPENDED
  PENDING_VERIFICATION
  DELETED
}

enum RequestStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
}

enum GameMode {
  CASUAL
  RANKED
  PRIVATE
  CUSTOM
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

enum CosmeticType {
  AVATAR
  CARD_BACK
  CARD_THEME
  CARD_ANIMATION
  TABLE_THEME
  PROFILE_BANNER
  BADGE
  TITLE
  EMOTE
  VOICE_PACK
}